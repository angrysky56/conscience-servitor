{
  "hipai-montague": {
    "command": "uv",
    "args": [
      "--directory",
      "/home/ty/Repositories/ai_workspace/HiPAI-Montague-Semantic-Cognition",
      "run", "python", "-m", "hipai.mcp_server"
    ],
    "env": { "PYTHONPATH": "src" }
  },
  "mcp-logic": {
